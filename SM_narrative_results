out_audit <- file.path(NARRATIVE_OUT_DIR, "SM_Narrative_Source_Audit.csv")
writeLines(combined_text, out_txt)
readr::write_csv(source_audit, out_audit)

message("Wrote combined SM narrative: ", out_txt)
message("Wrote SM narrative source audit: ", out_audit)

