  file.path(getwd(), "MRC_SM_workbook_and_plots_cleaned.R")
)
SM_WORKBOOK_SCRIPT <- SM_WORKBOOK_SCRIPT_CANDIDATES[file.exists(SM_WORKBOOK_SCRIPT_CANDIDATES)][1]

message("Using DATA_DIR: ", DATA_DIR)
