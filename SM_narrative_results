dir.create(NARRATIVE_OUT_DIR, recursive = TRUE, showWarnings = FALSE)

# Set FALSE if you have already run the SM workbook/plot script in this R session
# and only want to recollect the narrative text files.
RUN_SM_CALCULATION_SCRIPT <- TRUE

SCRIPT_DIR <- tryCatch(dirname(normalizePath(sys.frame(1)$ofile)), error = function(e) getwd())
SM_WORKBOOK_SCRIPT_CANDIDATES <- c(
