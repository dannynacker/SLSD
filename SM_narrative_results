# -----------------------------
# 5. Locate, read, and combine narrative files
# -----------------------------
source_audit <- sm_narrative_catalog %>%
  rowwise() %>%
  mutate(
    source_file = find_latest_file(unlist(patterns)),
    found = !is.na(source_file) & file.exists(source_file),
    source_file = if_else(found, normalizePath(source_file, winslash = "/"), NA_character_),
    n_lines = if_else(found, length(read_text_file(source_file)), 0L)
  ) %>%
  ungroup() %>%
  select(order, sm_section, label, found, source_file, n_lines)

section_blocks <- list()
for (i in seq_len(nrow(source_audit))) {
  row <- source_audit[i, ]
  header <- paste0("## ", row$sm_section, " — ", row$label)
  if (isTRUE(row$found)) {
    body <- clean_section_text(read_text_file(row$source_file))
  } else {
    body <- paste0(
      "[MISSING SOURCE] No narrative TXT was found for this section. ",
      "Check whether the relevant calculation block ran successfully, or whether this section should be regenerated from a frozen/static source."
    )
  }
  section_blocks[[i]] <- paste(header, body, sep = "\n\n")
}

combined_text <- paste(
  "SUPPLEMENTARY MATERIAL NARRATIVE — AUTO-GENERATED FROM CURRENT R OUTPUTS",
  "===============================================================",
  paste0("Generated: ", format(Sys.time(), "%Y-%m-%d %H:%M:%S")),
  paste0("DATA_DIR: ", DATA_DIR),
  "",
  paste(section_blocks, collapse = "\n\n------------------------------------------------------------\n\n"),
  sep = "\n"
)

