# -----------------------------
# 1. Packages
# -----------------------------
required_packages <- c("tidyverse", "readr", "stringr", "tibble")
missing_packages <- required_packages[!vapply(required_packages, requireNamespace, logical(1), quietly = TRUE)]
if (length(missing_packages) > 0) {
  stop(
    "Missing required packages: ", paste(missing_packages, collapse = ", "),
    "\nInstall them, then rerun this script."
  )
}

suppressPackageStartupMessages({
  library(tidyverse)
  library(readr)
  library(stringr)
  library(tibble)
})

# -----------------------------
# 2. Optionally rerun the SM workbook / plot calculations
# -----------------------------
if (RUN_SM_CALCULATION_SCRIPT) {
  if (is.na(SM_WORKBOOK_SCRIPT) || length(SM_WORKBOOK_SCRIPT) == 0) {
    stop(
      "Could not find MRC_SM_workbook_and_plots_cleaned.R. ",
      "Place it beside this script, in DATA_DIR, or in the working directory."
    )
  }
  message("Using SM workbook/plot calculation script: ", SM_WORKBOOK_SCRIPT)
  source(SM_WORKBOOK_SCRIPT, local = .GlobalEnv)
} else {
  message("RUN_SM_CALCULATION_SCRIPT is FALSE; collecting existing narrative outputs only.")
}

# -----------------------------
# 3. File search helpers
# -----------------------------
all_search_roots <- unique(c(DATA_DIR, OUTPUT_ROOT))
all_search_roots <- all_search_roots[dir.exists(all_search_roots)]

find_latest_file <- function(patterns, roots = all_search_roots) {
  hits <- character(0)
  for (root in roots) {
    files <- list.files(root, recursive = TRUE, full.names = TRUE)
    base <- basename(files)
    for (pat in patterns) {
      pat_regex <- pat |>
        stringr::str_replace_all("\\.", "\\\\.") |>
        stringr::str_replace_all("\\*", ".*")
      hits <- c(hits, files[stringr::str_detect(base, regex(pat_regex, ignore_case = TRUE))])
    }
  }
  hits <- unique(hits[file.exists(hits)])
  if (length(hits) == 0) return(NA_character_)
  hits[order(file.info(hits)$mtime, decreasing = TRUE)][1]
}

read_text_file <- function(path) {
  if (is.na(path) || !file.exists(path)) return(character(0))
  readLines(path, warn = FALSE, encoding = "UTF-8")
}

clean_section_text <- function(x) {
  x <- x[!is.na(x)]
  # Trim repeated empty lines but preserve paragraph breaks.
  joined <- paste(x, collapse = "\n")
  joined <- stringr::str_replace_all(joined, "\r\n", "\n")
  joined <- stringr::str_replace_all(joined, "\n{3,}", "\n\n")
  stringr::str_trim(joined)
}

